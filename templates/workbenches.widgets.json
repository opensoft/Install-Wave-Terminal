{
  "defwidget@terminal": {
    "display:order": -5,
    "icon": "square-terminal",
    "label": "terminal",
    "description": "Open the default WSL distro connection",
    "blockdef": {
      "meta": {
        "view": "term",
        "controller": "shell",
        "connection": "__WSL_CONNECTION__"
      }
    }
  },
  "projects": {
    "display:order": -4,
    "icon": "folder",
    "label": "projects",
    "description": "Open the WSL projects directory",
    "blockdef": {
      "meta": {
        "view": "preview",
        "connection": "__WSL_CONNECTION__",
        "file": "__PROJECTS_ROOT__"
      }
    }
  },
  "pyBench": {
    "icon": "brands@python",
    "label": "pyBench",
    "description": "Open the py-bench container shell",
    "blockdef": {
      "meta": {
        "view": "term",
        "controller": "shell",
        "frame:title": "pyBench",
        "connection": "__WSL_CONNECTION__",
        "cmd:cwd": "__WORKBENCHES_ROOT__",
        "cmd:initscript": "exec __WORKBENCHES_ROOT__/scripts/wave-container-shell.sh --title pyBench py-bench"
      }
    }
  },
  "flutterBench": {
