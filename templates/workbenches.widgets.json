        "cmd:cwd": "__WORKBENCHES_ROOT__",
        "cmd:initscript": "exec __WORKBENCHES_ROOT__/scripts/wave-container-shell.sh --title C++Bench C++Bench"
      }
    }
  },
  "cloudBench": {
